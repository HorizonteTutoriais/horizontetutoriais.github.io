// Variáveis globais para controle de paginação
let currentPage = 0;
const itemsPerPage = 12; // Exibir 12 itens por página
let currentCategory = 'home';
let allItems = [];

// Função para exibir os itens na grade
function displayItems(items, append = false) {
    const appGrid = document.getElementById('app-grid');
    if (!appGrid) return; // Garante que o elemento existe

    if (!append) {
        appGrid.innerHTML = ''; // Limpa a grade se não for para adicionar itens
    }

    const startIndex = currentPage * itemsPerPage;
    const endIndex = startIndex + itemsPerPage;
    const itemsToDisplay = items.slice(startIndex, endIndex);

    itemsToDisplay.forEach(item => {
        const itemCard = document.createElement('div');
        itemCard.className = 'item-card';
        itemCard.innerHTML = `
            <img src="${item.imagem}" alt="${item.nome}" class="item-image">
            <h3 class="item-name">${item.nome}</h3>
            <p class="item-description">${item.descricao}</p>
            <button class="details-button" onclick="openItemModal('${item.id}')">Detalhes</button>
        `;
        appGrid.appendChild(itemCard);
    });

    setupLoadMoreButton(items, endIndex);
}

// Função para configurar o botão "Carregar Mais"
function setupLoadMoreButton(items, endIndex) {
    const loadMoreContainer = document.getElementById('load-more-container');
    if (!loadMoreContainer) return; // Garante que o elemento existe

    loadMoreContainer.innerHTML = ''; // Limpa o container do botão

    if (endIndex < items.length) {
        const loadMoreButton = document.createElement('button');
        loadMoreButton.id = 'loadMoreButton';
        loadMoreButton.className = 'load-more-button';
        loadMoreButton.textContent = 'Carregar Mais';
        loadMoreButton.onclick = () => {
            currentPage++;
            displayItems(items, true);
        };
        loadMoreContainer.appendChild(loadMoreButton);
    }
}

// Função para filtrar e exibir itens por categoria
function filterAndDisplayItems(category) {
    currentCategory = category;
    currentPage = 0; // Resetar a página ao mudar de categoria
    let filteredItems = [];

    if (category === 'home') {
        // Lógica para a página inicial (pode exibir destaques, últimas atualizações, etc.)
        // Por enquanto, vamos exibir todos os itens para simplificar a demonstração da paginação
        filteredItems = allItems;
    } else {
        filteredItems = allItems.filter(item => {
            switch (category) {
                case 'aplicativos': return item.exibir?.emAplicativos;
                case 'jogos': return item.exibir?.emJogos;
                case 'tutoriais': return item.exibir?.emTutoriais;
                case 'ferramentas': return item.exibir?.emFerramentas;
                case 'quente': return item.exibir?.emQuente;
                default: return true;
            }
        });
    }

    displayItems(filteredItems);
}

// Funções para modais (mantidas do seu código original)
function openItemModal(itemId) {
    const item = allItems.find(i => i.id === itemId);
    if (!item) return;

    document.getElementById('modalImage').src = item.imagem;
    document.getElementById('modalName').textContent = item.nome;
    document.getElementById('modalDesc').textContent = item.descricao;

    const modalSpecs = document.getElementById('modalSpecs');
    modalSpecs.innerHTML = '';
    for (const key in item.especificacoes) {
        modalSpecs.innerHTML += `<p><strong>${key.charAt(0).toUpperCase() + key.slice(1)}:</strong> ${item.especificacoes[key]}</p>`;
    }

    const modalActions = document.getElementById('modalActions');
    modalActions.innerHTML = '';
    if (item.download) {
        modalActions.innerHTML += `<a href="${item.download}" class="download-button">Download</a>`;
    }
    if (item.downloads) {
        for (const key in item.downloads) {
            modalActions.innerHTML += `<a href="${item.downloads[key]}" class="download-button">${key.toUpperCase()}</a>`;
        }
    }
    if (item.guia_link) {
        modalActions.innerHTML += `<a href="${item.guia_link}" class="guide-button">Guia</a>`;
    }
    if (item.tutorial) {
        modalActions.innerHTML += `<button class="tutorial-button" onclick="openTutorialModal('${item.tutorial}')">Tutorial</button>`;
    }

    document.getElementById('itemModal').classList.add('active');
}

function openTutorialModal(videoUrl) {
    const tutorialModal = document.getElementById('tutorialModal');
    const tutVideo = document.getElementById('tutVideo');
    tutVideo.src = videoUrl;
    tutorialModal.classList.add('active');
}

function closeTutorial() {
    const tutorialModal = document.getElementById('tutorialModal');
    const tutVideo = document.getElementById('tutVideo');
    tutVideo.src = ''; // Para parar o vídeo
    tutorialModal.classList.remove('active');
}

function closeModal(id) {
    document.getElementById(id).classList.remove('active');
}

// Inicialização
document.addEventListener('DOMContentLoaded', () => {
    // Carregar itens do localStorage (se houver)
    HorizonteData.loadItemsFromStorage();
    allItems = HorizonteData.getAllItems();

    // Event listeners para navegação
    document.querySelectorAll('.nav-item').forEach(item => {
        item.addEventListener('click', (e) => {
            e.preventDefault();
            document.querySelectorAll('.nav-item').forEach(nav => nav.classList.remove('active'));
            e.target.classList.add('active');
            const page = e.target.dataset.page;

            document.getElementById('homeSections').style.display = 'none';
            document.getElementById('categorySection').style.display = 'none';

            if (page === 'home') {
                document.getElementById('homeSections').style.display = 'block';
                // Lógica para exibir destaques e últimas atualizações na home
                // displayItems(HorizonteData.getLatestUpdates()); // Exemplo
                // displayItems(HorizonteData.getHighlights()); // Exemplo
                filterAndDisplayItems('home'); // Exibe todos os itens na home por enquanto
            } else {
                document.getElementById('categorySection').style.display = 'block';
                document.getElementById('categoryTitle').textContent = e.target.textContent;
                filterAndDisplayItems(page);
            }
        });
    });

    // Ativar a categoria inicial (Home) ao carregar a página
    const homeNavItem = document.querySelector('.nav-item[data-page="home"]');
    if (homeNavItem) {
        homeNavItem.click();
    }

    // Dark Mode Toggle
    const darkModeToggle = document.getElementById('darkModeToggle');
    if (darkModeToggle) {
        darkModeToggle.addEventListener('click', () => {
            document.body.classList.toggle('dark-mode');
            const isDarkMode = document.body.classList.contains('dark-mode');
            darkModeToggle.textContent = isDarkMode ? '☀️' : '🌙';
            localStorage.setItem('darkMode', isDarkMode);
        });
        // Aplicar o modo escuro salvo
        if (localStorage.getItem('darkMode') === 'true') {
            document.body.classList.add('dark-mode');
            darkModeToggle.textContent = '☀️';
        }
    }

    // News Ticker
    const newsText = document.getElementById('newsText');
    const newsMessages = [
        'Bem-vindo ao seu site Horizonte Tutoriais, a sua fonte definitiva de aplicativos, tutoriais e jogos.',
        'Novos jogos e aplicativos adicionados semanalmente! Fique ligado!',
        'Siga-nos nas redes sociais para não perder nenhuma atualização!'
    ];
    let currentNewsIndex = 0;

    function updateNewsTicker() {
        newsText.textContent = newsMessages[currentNewsIndex];
        currentNewsIndex = (currentNewsIndex + 1) % newsMessages.length;
    }
    setInterval(updateNewsTicker, 5000); // Muda a notícia a cada 5 segundos

    // Inicializar o ticker
    updateNewsTicker();
});